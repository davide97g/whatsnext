# ─────────────────────────────────────────────────────────────
# whatsnext — environment variables
# Copy to .env for local dev. In Dokploy, set these per service.
# ─────────────────────────────────────────────────────────────

# ── API service ──────────────────────────────────────────────

# PostgreSQL connection string.
# Local docker-compose default:
DATABASE_URL=postgres://whatsnext:whatsnext@localhost:5432/whatsnext

# Port the Hono API listens on.
PORT=3000

# Comma-separated list of allowed CORS origins (the web app's URL).
# Local dev:
CORS_ORIGIN=http://localhost:5173

# Secret used to sign admin JWTs. Use a long random string.
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Single admin credentials.
# Generate the hash with:  bun run hash
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Token the Dokploy scheduled task sends as `x-sync-token` header to /api/sync/youtube.
#   openssl rand -hex 32
SYNC_TOKEN=change-me-to-a-long-random-string

# Discord webhook URL (channel → Integrations → Webhooks → New Webhook).
DISCORD_WEBHOOK_URL=

# YouTube Data API v3.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# When "true", newly synced YouTube items also fire a Discord notification.
NOTIFY_ON_SYNC=false

# ── Public channel links (served by GET /api/links) ──────────
DISCORD_INVITE_URL=https://discord.gg/your-invite
YOUTUBE_CHANNEL_URL=https://youtube.com/@your-channel
GITHUB_URL=https://github.com/your-handle
LINKEDIN_URL=https://linkedin.com/in/your-handle
CHANNEL_BLURB=Building things in public. Follow the roadmap for what's coming next.
CHANNEL_NAME=Davide Ghiotto

# ── Web service (build-time) ─────────────────────────────────
# Base URL of the API the web app talks to.
VITE_API_URL=http://localhost:3000
